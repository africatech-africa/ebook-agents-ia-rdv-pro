# ─────────────────────────────────────────────────────────────
# RDV-Pro — variables d'environnement
#
# Copie ce fichier vers .env :   cp .env.example .env
# puis renseigne tes clés. Le fichier .env n'est JAMAIS commité
# (voir .gitignore).
# ─────────────────────────────────────────────────────────────

# Clé API Google AI Studio — indispensable à partir du chapitre 2.
# Crée-la sur https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Port du serveur HTTP — utilisé à partir du chapitre 3.
PORT=3000

# Base de données Postgres (Neon) — utilisée à partir du chapitre 7.
# Crée une base gratuite sur https://neon.tech puis colle l'URL.
DATABASE_URL=

# Inngest — utilisé à partir du chapitre 8.
# En dev local : laisser INNGEST_DEV=1 (le SDK parle au dev server
# de inngest-cli sur http://127.0.0.1:8288). En production, laisser
# vide et fournir INNGEST_SIGNING_KEY + INNGEST_EVENT_KEY.
INNGEST_DEV=1

# Observabilité Langfuse — utilisée à partir du chapitre 11 (optionnel).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com
